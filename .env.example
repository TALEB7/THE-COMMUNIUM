# ======================================
# The Communium - Environment Variables
# ======================================
# Copy this file to apps/server/.env and apps/client/.env and fill in real values.

# ── SERVER (apps/server/.env) ──────────────────────────────────────────────

# App
NODE_ENV=development
PORT=4000

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/communium_db?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth (JWT session validation)
NEXTAUTH_SECRET=change_me_in_production

# JWT (internal service-to-service)
JWT_SECRET=change_me_in_production
JWT_EXPIRATION=7d

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# CMI (Moroccan payments)
CMI_MERCHANT_ID=xxxxxxxxxxxx
CMI_SECRET_KEY=xxxxxxxxxxxx
CMI_CALLBACK_URL=http://localhost:4000/api/payments/cmi/callback

# Meilisearch (search)
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your_meilisearch_key

# File Storage (Cloudflare R2 / S3)
S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
S3_ACCESS_KEY=xxxxxxxxxxxx
S3_SECRET_KEY=xxxxxxxxxxxx
S3_BUCKET=communium-uploads
S3_REGION=auto

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@communium.ma

# Frontend URLs (used for CORS and Stripe redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Uploads
UPLOADS_DIR=uploads

# AI Microservice
AI_SERVICE_URL=http://localhost:8000

# ── CLIENT (apps/client/.env) ──────────────────────────────────────────────

NEXTAUTH_SECRET=change_me_in_production

NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=http://localhost:4000
