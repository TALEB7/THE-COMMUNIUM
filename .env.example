# ======================================
# The Communium - Environment Variables
# ======================================

# App
NODE_ENV=development
PORT=4000

# Database (PostgreSQL)
DATABASE_URL="postgresql://communium:communium_secret@localhost:5432/communium_db?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_Z2xvcmlvdXMtd2FydGhvZy05Ny5jbGVyay5hY2NvdW50cy5kZXYk
CLERK_SECRET_KEY=sk_test_AzCEUNGyvkDYU85z0PBMSSaAlon03vF0HfevrqTBk8
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Stripe (International Payments)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# CMI (Moroccan Payments)
CMI_MERCHANT_ID=xxxxxxxxxxxx
CMI_SECRET_KEY=xxxxxxxxxxxx
CMI_CALLBACK_URL=http://localhost:4000/api/payments/cmi/callback

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=communium_meili_key

# File Storage (Cloudflare R2 / S3 compatible)
S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
S3_ACCESS_KEY=xxxxxxxxxxxx
S3_SECRET_KEY=xxxxxxxxxxxx
S3_BUCKET=communium-uploads
S3_REGION=auto

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@communium.ma

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="The Communium"

# JWT (for internal service-to-service)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d
